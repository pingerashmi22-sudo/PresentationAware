{
  "manifest_version": 3,
  "name": "PA-NEW",
  "version": "2.0",
  "description": "Real-time speech and slide awareness during presentations",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "https://docs.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/presentation/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}